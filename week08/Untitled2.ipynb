   "source": [
    "# 生成一个3x3矩阵中所有行索引大于列索引的坐标(row, col)\n",
    "coordinates = [(row, col) for row in range(3) for col in range(3) if row > col]\n",
    "print(coordinates)  # 输出: [(1, 0), (2, 0), (2, 1)]\n"
   ]
